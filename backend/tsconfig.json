{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",  // Changed from "commonjs"
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["node", "@types/express"]
  },
  "include": ["src/**/*"]
}