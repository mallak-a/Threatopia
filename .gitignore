# =============================================================================
# Threatopia — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Environment variables  (NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
backend/.env

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
# Next.js
.next/
out/

# TypeScript compiled output
backend/dist/
dist/

# TypeScript build info cache (can be regenerated)
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Large data files  (too large / not source code)
# -----------------------------------------------------------------------------
# Phishing URL detection dataset — 16.6 MB, regeneratable from source
URL Detection/processed_phishing_data.csv

# Any CSV datasets added in the future
*.csv

# ML model files
*.pkl
*.h5
*.pt
*.pth
*.onnx
*.joblib

# -----------------------------------------------------------------------------
# User-uploaded files  (runtime data, not source code)
# -----------------------------------------------------------------------------
backend/uploads/
uploads/

# -----------------------------------------------------------------------------
# Lock file duplicates / backups
# -----------------------------------------------------------------------------
*.backup
frontend/package-lock.json.backup
# Keep only one lockfile per package manager; pnpm-lock.yaml is a duplicate
# since the project uses npm. Remove the comment below if you switch to pnpm.
frontend/pnpm-lock.yaml

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / editor files
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# Keep shared editor config files (useful for the team)
!.vscode/extensions.json
!.vscode/tasks.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing / coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# v0 sandbox internal files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
next.user-config.*
.snowflake/
.v0-trash/
.vercel/

# Prisma generated client (regenerated by `npm run db:generate`)
backend/src/generated/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
.pytest_cache/
*.egg-info/

# Python virtual environments
venv/
.venv/
env/
.env/